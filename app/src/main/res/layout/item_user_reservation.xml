<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/surfaceVariant">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvResStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_pill_warning"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/success"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="CONFIRMED" />

        <TextView
            android:id="@+id/tvResId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="RES-4921" />

        <TextView
            android:id="@+id/tvResType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/warning"
            android:textColor="@color/warning"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvResId"
            app:layout_constraintStart_toEndOf="@id/tvResId"
            app:layout_constraintTop_toTopOf="@id/tvResId"
            tools:text="• VIP" />

        <TextView
            android:id="@+id/tvResEventName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/colorSecondary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvResId"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Annual Tech Symposium" />

        <TextView
            android:id="@+id/tvResDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            app:drawableStartCompat="@drawable/calender"
            app:drawableTint="@color/colorSecondary"
            android:drawablePadding="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvResEventName"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Oct 24, 2026  |  2 Seats" />
        <TextView
            android:id="@+id/tvResTimestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/colorSecondary"
            android:textSize="13sp"
            app:drawableStartCompat="@drawable/clock"
            app:drawableTint="@color/colorSecondary"
            android:drawablePadding="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvResDetails"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Reserved: 2026-06-22 16:31:17" />
        <TextView
            android:id="@+id/tvResAdditionalInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textStyle="italic"
            android:textColor="@color/colorSecondary"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tvResTimestamp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Note: Requires wheelchair accessibility." />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>