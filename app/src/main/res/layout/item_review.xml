<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/white">

    <ImageView
        android:id="@+id/ivReviewUserImage"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@color/surfaceVariant"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@tools:sample/avatars" />

    <TextView
        android:id="@+id/tvReviewUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/ivReviewUserImage"
        app:layout_constraintStart_toEndOf="@id/ivReviewUserImage"
        tools:text="Sarah Jenkins" />

    <RatingBar
        android:id="@+id/ratingBarReview"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:isIndicator="true"
        android:numStars="5"
        android:stepSize="0.5"
        android:progressTint="@color/warning"
        app:layout_constraintTop_toBottomOf="@id/tvReviewUserName"
        app:layout_constraintStart_toEndOf="@id/ivReviewUserImage"
        tools:rating="4.5" />

    <TextView
        android:id="@+id/tvReviewContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp"
        app:layout_constraintTop_toBottomOf="@id/ivReviewUserImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="The event was well organized, but the seating arrangement could have been better. Speakers were excellent!" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/surfaceVariant"
        app:layout_constraintTop_toBottomOf="@id/tvReviewContent" />

</androidx.constraintlayout.widget.ConstraintLayout>