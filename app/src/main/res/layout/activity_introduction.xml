<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageView_SplashLogo"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:contentDescription="logo"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4"
        app:shapeAppearanceOverlay="@style/CircleImageView" /><LinearLayout
    android:id="@+id/layout_IntroContent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="32dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:visibility="invisible"
    app:layout_constraintTop_toBottomOf="@id/imageView_SplashLogo"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:id="@+id/textView_AppTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Smart Campus System"
        android:textColor="@color/colorSecondary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:id="@+id/textView_AppDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textAlignment="center"
        android:lineSpacingExtra="6dp"
        android:paddingHorizontal="12dp"
        android:text="Your comprehensive platform for Birzeit University. Discover upcoming events, track academic schedules, and engage with campus life seamlessly."
        android:textColor="@color/black"
        android:textSize="16sp"
        android:alpha="0.75"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_Connect"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:layout_gravity="center_horizontal"
        android:text="Connect"
        android:textSize="18sp"
        android:textColor="@color/white"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="12dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"/>

</LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>